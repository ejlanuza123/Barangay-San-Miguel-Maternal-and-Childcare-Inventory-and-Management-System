        if (isFuture) {
            return "You cannot confirm visits for future dates.";
        }
        if (!isRegularVisitDay) {
            return "Visits can only be confirmed on Thursdays (regular visit days).";
        }
        return null;
    };

    return (
        <>
            <AnimatePresence>
                {showHistoryModal && selectedChild && (
                    <ChildHistoryModal 
                        child={selectedChild} 
                        onClose={() => setShowHistoryModal(false)} 
