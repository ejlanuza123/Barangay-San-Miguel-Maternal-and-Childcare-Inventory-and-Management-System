                    setVisits(visitsWithPatients);
                } else {
                    setVisits([]);
                }
            } catch (error) {
                console.error("Error fetching visit log:", error);
            } finally {
                setLoading(false);
            }
        };
        
        fetchVisits();
    }, [date]);

    return (
