                            roleFilter === role
                              ? "bg-blue-50 text-blue-600 font-semibold border border-blue-200"
                              : "text-gray-700 hover:bg-gray-100"
                          }`}
                        >
                          <div className="flex items-center justify-between">
                            <span>{role}</span>
                            {role !== "All" && <RoleBadge role={role} />}
                          </div>
                        </button>
                      ))}
                    </div>
