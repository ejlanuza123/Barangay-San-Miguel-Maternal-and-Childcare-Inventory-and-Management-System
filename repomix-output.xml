                                  required
                                  min="1"
                                  className="w-full p-2 border border-gray-300 rounded text-sm"
                                  placeholder="0"
                                />
                              </div>
                            </div>
                            <div className="grid grid-cols-2 gap-3">
                              <div>
                                <label className="text-xs font-medium text-gray-700 mb-1 block">
                                  <span className="text-red-500">*</span> Unit
                                </label>
                                <select
                                  value={item.unit || ""}
